{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sequence-brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagram_id",
    "diagram_type",
    "title",
    "summary",
    "participants",
    "messages"
  ],
  "properties": {
    "diagram_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "diagram_type": {
      "type": "string",
      "enum": ["sequence"]
    },
    "title": {
      "type": "string",
      "minLength": 4,
      "maxLength": 80
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "participants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "type": {
            "type": "string",
            "enum": ["actor", "participant", "database"]
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          }
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "description", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[MR][1-9][0-9]*$"
          },
          "from": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "to": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          },
          "type": {
            "type": "string",
            "enum": ["sync", "return", "async", "create", "destroy"]
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "include_legend"],
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["left_to_right", "top_to_bottom"]
        },
        "include_legend": {
          "type": "boolean"
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 60
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "participants"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "participants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 40
            }
          },
          "separator": {
            "type": "boolean",
            "description": "是否在该组相关消息段前添加 == 组名 == 分隔线；不得生成 PlantUML separator 关键字"
          }
        }
      }
    }
  }
}
