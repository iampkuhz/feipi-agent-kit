{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "architecture-brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagram_id",
    "diagram_type",
    "title",
    "summary",
    "layers",
    "components",
    "flows"
  ],
  "properties": {
    "diagram_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "diagram_type": {
      "type": "string",
      "enum": ["architecture"]
    },
    "title": {
      "type": "string",
      "minLength": 4,
      "maxLength": 80
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "layers": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "color"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30,
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          },
          "color": {
            "type": "string",
            "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$"
          }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "layer", "type", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "layer": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30
          },
          "type": {
            "type": "string",
            "enum": ["actor", "component", "database", "queue", "cloud", "interface"]
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S[1-9][0-9]*$"
          },
          "from": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "to": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "include_legend"],
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["top_to_bottom"]
        },
        "include_legend": {
          "type": "boolean"
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 60
      }
    }
  }
}
