@startuml
title 电商下单链路架构图
top to bottom direction
skinparam nodesep 8
skinparam ranksep 70

package "接入层" #D6EAF8 {
  actor "用户" as user
  component "商城前台" as web_portal
}

package "应用层" #D5F5E3 {
  component "订单服务" as order_service
  component "库存服务" as inventory_service
  cloud "支付网关" as payment_gateway
  component "埋点服务" as metrics_service
}

package "数据层" #FCF3CF {
  database "订单库" as order_db
}

user --> web_portal : S1 提交下单请求
web_portal --> order_service : S2 转发创建订单请求
order_service --> payment_gateway : S4 发起支付
order_service --> order_db : S5 写入订单记录
@enduml
