# Crawl4AI Service 环境变量模板
# 复制到 .env 后使用：cp .env.example .env

# ==============================================================================
# [可选] LLM 配置 - 仅在使用 /llm/* 或 md?f=llm 时需要
# ==============================================================================

# OpenAI
# OPENAI_API_KEY=sk-xxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini
# GEMINI_API_KEY=xxx

# 当前仓库默认使用 tools/crawl/crawl4ai/config/config.yml 作为服务端真配置。

# ==============================================================================
# [可选] 代理配置（用于访问受限网站）
# ==============================================================================

# HTTP_PROXY=http://host.containers.internal:7890
# HTTPS_PROXY=http://host.containers.internal:7890
# NO_PROXY=127.0.0.1,localhost,0.0.0.0,::1,host.containers.internal
# no_proxy=127.0.0.1,localhost,0.0.0.0,::1,host.containers.internal
