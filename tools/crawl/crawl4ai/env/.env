# Crawl4AI Service 环境变量模板
# 复制到 .env 后使用：cp .env.example .env

# ==============================================================================
# [可选] LLM API Keys - 用于内容分析和提取
# ==============================================================================

# OpenAI
# OPENAI_API_KEY=sk-xxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini
# GEMINI_API_KEY=xxx

# ==============================================================================
# [可选] Crawl4AI 基础配置
# ==============================================================================

# Crawl4AI 服务端口
CRAWL4AI_PORT=11235

# 浏览器类型（chromium, firefox, webkit）
CRAWL4AI_BROWSER=chromium

# 无头模式
CRAWL4AI_HEADLESS=true

# ==============================================================================
# [可选] 代理配置（用于访问受限网站）
# ==============================================================================

# HTTP_PROXY=http://host.containers.internal:7890
# HTTPS_PROXY=http://host.containers.internal:7890
