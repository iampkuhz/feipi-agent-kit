# LiteLLM 轻量代理 - 环境变量模板
# 使用说明：
# 1. 复制此文件：cp tools/gateway/litellm/env/.env.example tools/gateway/litellm/env/.env
# 2. 编辑 tools/gateway/litellm/env/.env，填入真实值
# 3. 启动前确保已 source tools/gateway/litellm/env/.env

# ==============================================================================
# [必需] LiteLLM 基础配置
# ==============================================================================

# LiteLLM 网关访问 token（客户端调用时需携带此 token）
# 生成命令：openssl rand -hex 16
LITELLM_MASTER_KEY=replace-with-a-long-random-token

# ==============================================================================
# [必需] 百炼 OpenAI 兼容模型
# ==============================================================================

# 逻辑模型名（客户端调用时使用的 model 参数）
LITELLM_CODE_MODEL_OPENAI=qwen-openai

# 上游模型配置
LITELLM_UPSTREAM_CODE_MODEL_OPENAI_NAME=qwen-plus
LITELLM_UPSTREAM_CODE_MODEL_OPENAI_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LITELLM_UPSTREAM_CODE_MODEL_OPENAI_KEY=replace-with-your-bailian-api-key

# ==============================================================================
# [必需] 百炼 Anthropic 兼容模型
# ==============================================================================

# 逻辑模型名（客户端调用时使用的 model 参数）
LITELLM_CODE_MODEL_ANTHROPIC=qwen-anthropic

# 上游模型配置
LITELLM_UPSTREAM_CODE_MODEL_ANTHROPIC_NAME=qwen-plus
LITELLM_UPSTREAM_CODE_MODEL_ANTHROPIC_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LITELLM_UPSTREAM_CODE_MODEL_ANTHROPIC_KEY=replace-with-your-bailian-api-key

# ==============================================================================
# [可选] 本地补全模型（OpenAI 兼容）
# ==============================================================================

# 逻辑模型名
LITELLM_AUTOCOMPLETE_MODEL_OPENAI=qwen-autocomplete

# 上游模型配置
LITELLM_UPSTREAM_AUTOCOMPLETE_MODEL_OPENAI_NAME=qwen-turbo
LITELLM_UPSTREAM_AUTOCOMPLETE_MODEL_OPENAI_BASE=http://localhost:11434/v1
LITELLM_UPSTREAM_AUTOCOMPLETE_MODEL_OPENAI_KEY=

# ==============================================================================
# [必需] 数据库配置（LiteLLM Proxy 必需）
# ==============================================================================

# PostgreSQL 数据库密码（默认：litellm_password）
# 建议修改为随机生成的安全密码
POSTGRES_PASSWORD=litellm_password

# PostgreSQL 数据库连接字符串
# 格式：postgresql://用户名：密码@主机：端口/数据库名
# 默认配置与 docker-compose.yml 中的 PostgreSQL 服务匹配
# 容器内使用：postgresql://litellm:litellm_password@litellm-db:5432/litellm
# 宿主机使用：postgresql://litellm:litellm_password@localhost:5432/litellm
DATABASE_URL=postgresql://litellm:litellm_password@localhost:5432/litellm

# ==============================================================================
# [可选] OpenTelemetry 配置（用于接入 Braintrust / Arize AX）
# 不接云端观测平台时可留空
# ==============================================================================

# OTel 端点（例如：https://otlp.braintrust.dev）
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTel 请求头（例如：Authorization=Bearer your-api-key）
OTEL_EXPORTER_OTLP_HEADERS=

# 是否启用 Request Span（true/false）
USE_OTEL_LITELLM_REQUEST_SPAN=false
